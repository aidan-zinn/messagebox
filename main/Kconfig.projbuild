menu "Messagebox Configuration"

    config WIFI_SSID
        string "WiFi SSID"
        default "myssid"

    config WIFI_PASSWORD
        string "WiFi Password"
        default "mypassword"

    config MQTT_BROKER_URI
        string "MQTT Broker URI"
        default "mqtt://broker.hivemq.com"

    config MQTT_TOPIC
        string "MQTT Topic"
        default "lovebox/message"

endmenu
